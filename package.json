{
  "name": "markdown-nexus",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "generate:icons": "node generate-icon.js",
    "build": "npm run generate:icons && webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "watch": "webpack --config webpack.config.js --watch",
    "dev": "concurrently \"npm run watch\" \"electron .\"",
    "package": "npm run generate:icons && webpack --config webpack.config.js --mode production && electron-builder build --win && node zip-executables.js",
    "package-mac": "npm run generate:icons && webpack --config webpack.config.js --mode production && electron-builder build --mac",
    "package-linux": "npm run generate:icons && webpack --config webpack.config.js --mode production && electron-builder build --linux",
    "dist": "npm run build && electron-builder build --win"
  },
  "keywords": [
    "electron",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "description": "A multi-tab Markdown editor with live preview",
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/turndown": "^5.0.6",
    "concurrently": "^9.1.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "html-webpack-plugin": "^5.6.3",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.8",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mozilla/readability": "^0.6.0",
    "@mui/material": "^7.3.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "diff": "^8.0.3",
    "dotenv": "^17.2.4",
    "jsdom": "^27.0.1",
    "lucide-react": "^0.542.0",
    "mermaid": "^11.12.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.2"
  },
  "build": {
    "appId": "com.markdownnexus.app",
    "productName": "Markdown Nexus",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mdown",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mkd",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mkdn",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mdx",
        "name": "MDX",
        "description": "MDX document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mdwn",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "mdc",
        "name": "Markdown",
        "description": "Markdown document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "rst",
        "name": "reStructuredText",
        "description": "reStructuredText document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      },
      {
        "ext": "rest",
        "name": "reStructuredText",
        "description": "reStructuredText document",
        "icon": "assets/icon-padded.png",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon-padded.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon-padded.png"
    }
  }
}
